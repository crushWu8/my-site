.pe-cloud::-webkit-scrollbar-thumb{background:var(--pe-chip-border); border-radius:8px}
.pe-cloud::-webkit-scrollbar-track{background:transparent}
.pe-tag{font-family:"JetBrains Mono",monospace; font-size:12.5px; padding:6px 10px; border-radius:6px;
  background:var(--pe-chip); border:1px solid var(--pe-chip-border); color:var(--pe-text); cursor:default;
  transition:background .15s ease, color .15s ease, border-color .15s ease, transform .15s ease}
.pe-tag:hover, .pe-tag:focus-visible{background:rgba(230,57,70,.14); border-color:var(--pe-red); color:var(--pe-strong); transform:translateY(-1px); outline:none}
.pe-tag-market:hover{background:rgba(6,182,160,.14); border-color:var(--pe-teal); color:var(--pe-strong)}
@media(max-width:760px){
  .pe-compare{grid-template-columns:1fr; gap:36px}
  .pe-compare-div{display:none}
}

/* tooltip */
.pe-tooltip{position:fixed; z-index:9999; max-width:300px; padding:12px 14px; border-radius:10px;
  background:#1b1b1b; border:1px solid #333; color:#eee; font-family:"Inter",sans-serif; font-size:14px; line-height:1.45;
  box-shadow:0 14px 40px rgba(0,0,0,.6); pointer-events:none; opacity:0; transform:translateY(6px);
  transition:opacity .12s ease, transform .12s ease}
:root[data-theme="light"] .pe-tooltip{background:#ffffff; border-color:#e2e5e9; color:#1f2937; box-shadow:0 14px 40px rgba(0,0,0,.18)}
.pe-tooltip.show{opacity:1; transform:none}

/* pull quote */

/* ---------- Section 4 · Calculator ---------- */
.pe-foot-note{font-family:"JetBrains Mono",monospace; font-size:12px!important; color:var(--pe-muted); border-left:2px solid var(--pe-line); padding-left:14px; margin-top:8px!important}
.pe-calc{margin:48px 0; padding:32px; background:var(--pe-surface); border:1px solid var(--pe-line); border-radius:16px}
.pe-switches{display:grid; gap:22px; margin-bottom:36px}
.pe-switch{display:grid; grid-template-columns:140px 1fr; gap:18px; align-items:center}
.pe-switch-label{font-weight:600; color:var(--pe-strong); font-size:15px; display:flex; align-items:center; gap:7px}
.pe-info{display:inline-flex; width:16px; height:16px; border-radius:50%; border:1px solid var(--pe-chip-border); color:var(--pe-muted);
  font-size:10px; align-items:center; justify-content:center; cursor:help; font-family:"JetBrains Mono",monospace}
.pe-opts{display:flex; flex-wrap:wrap; gap:8px}
.pe-opt{font-size:13px; padding:8px 13px; border-radius:8px; background:var(--pe-chip); border:1px solid var(--pe-chip-border); color:var(--pe-text);
  cursor:pointer; transition:all .15s ease; font-family:"Inter",sans-serif}
.pe-opt:hover{border-color:var(--pe-muted); color:var(--pe-strong)}
.pe-opt.sel{background:rgba(230,57,70,.16); border-color:var(--pe-red); color:var(--pe-strong)}
.pe-opt .pe-opt-mult{font-family:"JetBrains Mono",monospace; font-size:11px; color:var(--pe-muted); margin-left:6px}
.pe-opt.sel .pe-opt-mult{color:var(--pe-red)}

.pe-bars{display:grid; gap:18px}
.pe-bar-row{display:grid; grid-template-columns:200px 1fr auto; gap:16px; align-items:center}
.pe-bar-label{font-size:13px; color:var(--pe-lead); line-height:1.3}
.pe-bar-sub{display:block; font-size:11px; color:var(--pe-muted)}
.pe-bar-track{height:14px; background:var(--pe-track); border-radius:8px; overflow:hidden}
.pe-bar-fill{height:100%; width:0; border-radius:8px; transition:width .35s cubic-bezier(.4,0,.2,1)}
.teal-bg{background:var(--pe-teal)} .red-bg{background:var(--pe-red)} .darkred-bg{background:var(--pe-darkred)}
.pe-bar-amt{font-family:"JetBrains Mono",monospace; font-weight:700; font-size:20px; text-align:right; min-width:84px}
.pe-bar-amt.big{font-size:30px}
.pe-bar-you .pe-bar-label{color:var(--pe-strong); font-weight:600}
.pe-delta{margin-top:10px; font-size:16px; color:var(--pe-strong); font-weight:600; text-align:center; padding-top:18px; border-top:1px solid var(--pe-line)}
.pe-delta .red{font-weight:800}
.pe-shake{animation:pe-shake .4s ease}
@keyframes pe-shake{0%,100%{transform:translateX(0)}20%{transform:translateX(-5px)}40%{transform:translateX(5px)}60%{transform:translateX(-3px)}80%{transform:translateX(3px)}}
@media(max-width:640px){
  .pe-switch{grid-template-columns:1fr; gap:8px}
  .pe-bar-row{grid-template-columns:1fr auto; gap:10px}
  .pe-bar-track{grid-column:1 / -1; order:3}
}

.pe-reveal-block{margin-top:64px; padding-top:40px; border-top:1px solid var(--pe-line)}
.pe-kicker{font-size:clamp(20px,3vw,26px)!important; font-weight:700; color:var(--pe-strong); margin-top:24px!important}

/* ---------- Section 5 · The cost (figures) ---------- */
.pe-sep{border:none; border-top:1px solid var(--pe-line); margin:64px 0}
.pe-fig{margin:0}
.pe-cost-close{font-size:clamp(20px,3vw,26px)!important; font-weight:600; color:var(--pe-strong); text-align:center; max-width:30ch; margin:8px auto 0!important; line-height:1.4}

/* figure card: a fixed cream "paper" surface in both themes */
.pe-figure{background:#F8F6F1; color:#2a2a2a; border:1px solid #e6e1d6; border-radius:14px; padding:28px; margin:0 0 22px}
.pe-figure *{color:inherit}
.pe-fig-head{display:flex; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:22px}
.pe-fig-title{font-family:"Inter",sans-serif; font-weight:800; font-size:clamp(16px,2.4vw,20px); color:#1a1a1a}
.pe-fig-read{margin:0 0 4px}
.pe-fig-read p{font-size:15px!important; color:var(--pe-text); margin:0 0 12px}
.pe-fig-note{font-family:"JetBrains Mono",monospace; font-size:11px!important; color:#7a756a!important; margin:18px 0 0!important; line-height:1.5}
.pe-fig-kicker{font-weight:700; color:#1a1a1a!important; margin:20px 0 0!important; font-size:14px!important}

/* Fig 1 · battery bar chart */
.pe-batt-icon{position:relative; width:64px; height:30px; border:2px solid #2a2a2a; border-radius:6px; padding:3px; display:inline-block; flex:none}
.pe-batt-icon::after{content:""; position:absolute; right:-7px; top:8px; width:4px; height:12px; background:#2a2a2a; border-radius:0 2px 2px 0}
.pe-batt-fill{display:block; height:100%; border-radius:3px}
.pe-batt-icon.sm{width:34px; height:17px; border-width:1.5px; padding:2px; border-radius:4px}
.pe-batt-icon.sm::after{right:-4px; top:5px; width:3px; height:7px}
.pe-bc-sub{font-family:"JetBrains Mono",monospace; font-size:11px; color:#9a958a; margin:-8px 0 20px}
.pe-battchart{display:grid; gap:18px; margin:0 0 4px}
.pe-bc-row{display:grid; grid-template-columns:88px 1fr; gap:16px; align-items:center}
.pe-bc-label{display:flex; align-items:center; gap:9px; font-family:"JetBrains Mono",monospace; font-weight:700; font-size:13px; color:#2a2a2a}
.pe-bc-bars{display:flex; flex-direction:column; gap:6px; min-width:0}
.pe-bc-track{position:relative; height:22px; background:#ebe7de; border-radius:6px; overflow:hidden}
.pe-bc-fill{height:100%; border-radius:6px; transition:width .6s cubic-bezier(.4,0,.2,1)}
.pe-bc-flag{position:absolute; right:10px; top:50%; transform:translateY(-50%); font-family:"JetBrains Mono",monospace; font-size:10px; font-weight:700; color:#fff; letter-spacing:.04em}
.pe-bc-mono{font-family:Georgia,"Times New Roman",serif; font-style:italic; font-size:14px; color:#5a554c}
.pe-fig-rule{border:none; border-top:1px solid #e6e1d6; margin:24px 0}
.pe-quote{margin:0; padding:2px 0 2px 16px; border-left:3px solid #d9d3c7; background:none;
  font-family:Georgia,"Times New Roman",serif; font-size:16px; font-style:italic; line-height:1.5; color:#3a3a3a}
.pe-quote cite{display:block; margin-top:10px; font-style:normal; font-family:"JetBrains Mono",monospace; font-size:11px; color:#8a857a}

/* Fig 2 · bar chart */
.pe-bars2-cap, .pe-line-cap{font-family:"JetBrains Mono",monospace; font-size:12px; color:#7a756a; margin-bottom:14px}
.pe-bars2{display:flex; justify-content:center; align-items:flex-end; gap:64px; height:220px; padding:0 20px}
.pe-bar2-col{display:flex; flex-direction:column; align-items:center; height:100%; justify-content:flex-end; gap:10px; width:120px}
.pe-bar2-val{font-family:"JetBrains Mono",monospace; font-weight:700; font-size:18px; color:#1a1a1a}
.pe-bar2-track{width:90px; height:160px; display:flex; align-items:flex-end}
.pe-bar2{width:100%; border-radius:6px 6px 0 0; transition:height .6s cubic-bezier(.4,0,.2,1)}
.pe-bar2-name{font-family:"Inter",sans-serif; font-weight:600; font-size:14px; color:#2a2a2a}

/* Fig 3 · line chart */
.pe-linechart{width:100%; height:auto; display:block}
.pe-events{list-style:none; margin:20px 0 0; padding:0; display:grid; grid-template-columns:repeat(2,1fr); gap:8px 24px}
.pe-events li{font-size:13px; color:#2a2a2a; border:none; padding:0}
.pe-ev-yr{font-family:"JetBrains Mono",monospace; font-weight:700; color:#E63946; margin-right:8px}

/* Fig 4 · stacked concept */
.pe-stack{display:flex; align-items:flex-end; justify-content:center; gap:0; height:280px; padding:0 10px}
.pe-stack-col{display:flex; flex-direction:column; align-items:center; gap:12px; width:150px}
.pe-stack-bar{width:96px; height:220px; display:flex; flex-direction:column; border-radius:6px; overflow:hidden}
.pe-stack-seg{display:flex; align-items:center; justify-content:center; text-align:center; transition:height .6s cubic-bezier(.4,0,.2,1)}
.pe-stack-seg span{font-family:"Inter",sans-serif; font-size:11px; font-weight:600; color:#fff; padding:0 4px; line-height:1.2}
.seg-profit{background:#E63946}
.seg-surplus{background:#06B6A0}
.pe-stack-name{font-family:"Inter",sans-serif; font-weight:700; font-size:14px; color:#2a2a2a; text-align:center; line-height:1.3}
.pe-stack-name span{font-family:"JetBrains Mono",monospace; font-weight:500; font-size:11px; color:#7a756a}
.pe-stack-arrow{align-self:center; display:flex; flex-direction:column; align-items:center; padding:0 10px; min-width:120px}
.pe-stack-arrow::after{content:""; width:100%; height:2px; background:#1a1a1a; position:relative}
.pe-stack-arrow-label{font-family:"JetBrains Mono",monospace; font-size:12px; font-weight:700; color:#1a1a1a; margin-bottom:8px; text-align:center}
@media(max-width:560px){
  .pe-events{grid-template-columns:1fr}
  .pe-stack{gap:0} .pe-stack-arrow{min-width:80px}
  .pe-bars2{gap:36px}
}

/* ---------- Sources ---------- */
.pe-sources{padding-top:48px; padding-bottom:120px}
.pe-refs{font-family:"JetBrains Mono",monospace; font-size:12.5px; color:var(--pe-muted); line-height:1.7; padding-left:20px}
.pe-refs li{margin-bottom:12px}
.pe-refs em{font-style:italic; color:#999}

@media(prefers-reduced-motion:reduce){
  .pe .reveal,.pe-num-lg{transition:none!important}
  .pe-down{animation:none}
}
</style>

<script>
(function(){
  if (window.__peInit) return; window.__peInit = true;

  /* ---------- reveal on scroll ---------- */
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  }, {threshold:.18});
  document.querySelectorAll('.pe .reveal').forEach(function(el){ io.observe(el); });

  /* ---------- Section 2 · 47-factor tag cloud ---------- */
  // Factor descriptions and sources are kept here as comments for later use (not shown on hover for now).
  var FACTORS = [
    "Device type",               // iPhone users are quoted higher prices. (Mone et al., 2026)
    "Device model",              // Newer, pricier hardware signals higher willingness to pay. (FTC 6(b))
    "Operating system",          // iOS vs Android shifts your baseline price. (FTC 6(b))
    "OS version",                // An up-to-date OS hints at a higher-spending profile. (FTC 6(b))
    "Browser",                   // Browser choice correlates with spending habits. (FTC 6(b))
    "Browser version",           // A stale version can flag a price-sensitive user. (FTC 6(b))
    "Screen size",               // Larger, premium screens nudge the price up. (FTC 6(b))
    "Screen resolution",         // High-DPI displays signal a premium device. (FTC 6(b))
    "Language setting",          // Your locale decides which price tier you land in. (FTC 6(b))
    "Time-zone setting",         // Reveals where and when you really are. (FTC 6(b))
    "Battery level",             // Low battery reads as urgency, so the price goes up. (Kumar et al., 2026)
    "IP address",                // Maps you to a region and a price band. (FTC 6(b))
    "Precise GPS location",      // Pins you to a neighborhood-level price. (FTC 6(b))
    "Home ZIP code",             // Used to infer income and adjust the quote. (FTC 6(b))
    "Neighborhood income",       // Wealthier blocks get higher quotes. (FTC 6(b))
    "Neighborhood crime rate",   // Feeds risk and urgency models. (Kumar et al., 2026)
    "Nearby service density",    // Fewer alternatives nearby means a higher price. (Kumar et al., 2026)
    "Country",                   // Sets your national price tier. (FTC 6(b))
    "City",                      // City-level demand shifts your price. (FTC 6(b))
    "Distance to a store",       // Far from a store means less ability to walk away. (FTC 6(b))
    "Mouse-movement path",       // Hesitation and hovering reveal intent. (FTC 6(b))
    "Scroll speed",              // Fast scrolling vs careful reading signals urgency. (FTC 6(b))
    "Scroll depth",              // How far you read flags how committed you are. (FTC 6(b))
    "Time on page",              // Longer dwell time reads as higher intent. (FTC 6(b))
    "Click pattern",             // Repeated clicks signal you're hooked. (FTC 6(b))
    "Video watch ratio",         // Finishing the demo flags strong interest. (FTC 6(b))
    "Move toward close button",  // Exit intent can trigger a different price. (FTC 6(b))
    "Tab switching",             // Comparison-shopping behavior is detected. (FTC 6(b))
    "Sites visited (30 days)",   // Your browsing trail builds a spending profile. (FTC 6(b))
    "Similar products browsed",  // Past browsing predicts willingness to pay. (Shiller, 2020)
    "Cart added then abandoned", // Abandonment is read as a price-sensitivity signal. (FTC 6(b))
    "Purchase history",          // What you bought before predicts what you'll pay now. (Shiller, 2020)
    "Inferred price sensitivity",// A model guesses how much a discount sways you. (Shiller, 2020)
    "Searches for this item",    // Repeated searches read as rising intent. (FTC 6(b))
    "Cross-device behavior",     // Your phone and laptop are linked into one profile. (FTC 6(b))
    "Membership tier",           // Loyalty status can raise or lower your price. (FTC 6(b))
    "Account age",               // How long you've been a customer shifts the quote. (FTC 6(b))
    "Email address",             // The hub that ties every other signal together. (FTC 6(b))
    "Payment method",            // Card vs wallet hints at spending power. (FTC 6(b))
    "Card-issuing bank",         // Your bank can act as a proxy for income. (FTC 6(b))
    "Gender",                    // Inferred gender feeds the price model. (FTC 6(b))
    "Inferred household stage",  // Labels like 'new parent' target your urgency. (FTC 6(b))
    "Current time",              // Time of day shifts demand and price. (FTC 6(b))
    "Day of week",               // Weekday vs weekend changes the quote. (FTC 6(b))
    "Local weather",             // Weather nudges demand-based pricing. (FTC 6(b))
    "Local events",              // A nearby concert or game spikes prices. (FTC 6(b))
    "Nearby search volume"       // Rising demand around you raises your price. (FTC 6(b))
  ];
  var cloud = document.getElementById('pe-cloud');
  var tip = document.getElementById('pe-tooltip');
  function showTip(html, x, y){
    tip.innerHTML = html;
    tip.setAttribute('aria-hidden','false');
    tip.classList.add('show');
    var r = tip.getBoundingClientRect();
    var left = Math.min(Math.max(8, x - r.width/2), window.innerWidth - r.width - 8);
    var top = y - r.height - 14;
    if (top < 8) top = y + 20;
    tip.style.left = left + 'px';
    tip.style.top = top + 'px';
  }
  function hideTip(){ tip.classList.remove('show'); tip.setAttribute('aria-hidden','true'); }
  // Render labels only. No hover tooltip, so the You factors behave like the Market factors.
  FACTORS.forEach(function(label){
    var t = document.createElement('span');
    t.className = 'pe-tag'; t.textContent = label;
    t.setAttribute('role','listitem');
    cloud.appendChild(t);
  });

  /* ---------- Section 4 · price calculator ---------- */
  var BASELINE = 12.00, WORST = 34.80;
  var SWITCHES = [
    {key:'phone', label:'Phone', info:'iPhone users have been quoted about 4% more in documented cases (Mone et al., 2026).',
     opts:[['iPhone (new)',.08],['iPhone (older)',.04],['Android (flagship)',.03],['Android (basic)',0]], def:0},
    {key:'area', label:'Neighborhood', info:'ZIP code and block-level income are used to infer how much you can pay (FTC 6(b)).',
     opts:[['High-income',.10],['Middle-income',.03],['Low-income',0]], def:1},
    {key:'time', label:'Time of day', info:'Late-night demand has been linked to higher quotes (Kumar et al., 2026).',
     opts:[['Work hours',0],['Evening',.03],['Late night',.06],['Weekend',.02]], def:1},
    {key:'search', label:'Searches', info:'More searches signal stronger intent, which models price higher (Shiller, 2020).',
     opts:[['1st time',0],['2-4 times',.05],['5+ times',.09]], def:1},
    {key:'battery', label:'Battery', info:'Low battery reads as urgency, and you cannot shop around forever (Kumar et al., 2026).',
     opts:[['Above 50%',0],['20-50%',.06],['Below 20%',0.12]], def:1}
  ];
  var state = {};
  var switchesEl = document.getElementById('pe-switches');
  SWITCHES.forEach(function(sw){
    state[sw.key] = sw.opts[sw.def][1];
    var row = document.createElement('div'); row.className = 'pe-switch';
    var lab = document.createElement('div'); lab.className = 'pe-switch-label';
    lab.innerHTML = sw.label + ' <span class="pe-info" tabindex="0" role="img" aria-label="info">i</span>';
    var infoBtn = lab.querySelector('.pe-info');
    infoBtn.addEventListener('mouseenter', function(){ var r=infoBtn.getBoundingClientRect(); showTip(sw.info, r.left+r.width/2, r.top); });
    infoBtn.addEventListener('mouseleave', hideTip);
    infoBtn.addEventListener('focus', function(){ var r=infoBtn.getBoundingClientRect(); showTip(sw.info, r.left+r.width/2, r.top); });
    infoBtn.addEventListener('blur', hideTip);
    var opts = document.createElement('div'); opts.className = 'pe-opts';
    sw.opts.forEach(function(o, i){
      var b = document.createElement('button'); b.type='button'; b.className='pe-opt' + (i===sw.def?' sel':'');
      b.innerHTML = o[0] + '<span class="pe-opt-mult">' + (o[1]>0?'+'+Math.round(o[1]*100)+'%':'0%') + '</span>';
      b.addEventListener('click', function(){
        opts.querySelectorAll('.pe-opt').forEach(function(x){x.classList.remove('sel');});
        b.classList.add('sel'); state[sw.key] = o[1]; render();
      });
      opts.appendChild(b);
    });
    row.appendChild(lab); row.appendChild(opts); switchesEl.appendChild(row);
  });

  var barBase = document.getElementById('pe-bar-base'), barYou = document.getElementById('pe-bar-you'), barWorst = document.getElementById('pe-bar-worst');
  var amtBase = document.getElementById('pe-amt-base'), amtYou = document.getElementById('pe-amt-you'), amtWorst = document.getElementById('pe-amt-worst');
  var deltaEl = document.getElementById('pe-delta');
  var prevPct = 0, tween;
  function tweenNum(el, from, to){
    cancelAnimationFrame(tween); var start=null, dur=320;
    function step(ts){ if(!start) start=ts; var p=Math.min((ts-start)/dur,1);
      var v = from + (to-from)*(p<.5?2*p*p:1-Math.pow(-2*p+2,2)/2);
      el.textContent = '$' + v.toFixed(2); if(p<1) tween=requestAnimationFrame(step); }
    tween = requestAnimationFrame(step);
  }
  function render(){
    var sum = 0; for (var k in state) sum += state[k];
    var you = BASELINE * (1 + sum);
    var max = WORST;
    barBase.style.width = (BASELINE/max*100) + '%';
    barYou.style.width  = (you/max*100) + '%';
    barWorst.style.width = '100%';
    var prevYou = parseFloat(amtYou.textContent.replace('$','')) || BASELINE;
    tweenNum(amtYou, prevYou, you);
    amtBase.textContent = '$' + BASELINE.toFixed(2);
    amtWorst.textContent = '$' + WORST.toFixed(2);
    var diff = you - BASELINE, pct = Math.round(diff/BASELINE*100);
    deltaEl.innerHTML = diff <= 0.005
      ? 'You’re at the baseline price, for now.'
      : 'You’d pay <span class="red">$' + diff.toFixed(2) + '</span> more than baseline. That’s <span class="red">' + pct + '% more</span>.';
    if (pct > 50 && prevPct <= 50){ amtYou.classList.remove('pe-shake'); void amtYou.offsetWidth; amtYou.classList.add('pe-shake'); }
    prevPct = pct;
  }
  render();
})();
</script>]]></content><author><name>Shanghao Wu</name></author><summary type="html"><![CDATA[How algorithms quietly redefine the relationship between you and the market.]]></summary></entry><entry><title type="html">Hello, world.</title><link href="http://localhost:4001/my-site/blog/hello-world/" rel="alternate" type="text/html" title="Hello, world." /><published>2026-05-14T00:00:00-04:00</published><updated>2026-05-14T00:00:00-04:00</updated><id>http://localhost:4001/my-site/blog/hello-world</id><content type="html" xml:base="http://localhost:4001/my-site/blog/hello-world/"><![CDATA[<p>Starting a blog feels like buying a new notebook — half the value is the blank page in front of you, and half is the quiet promise that you’ll show up to fill it.</p>

<p>I plan to write here about three kinds of things:</p>

<ul>
  <li><strong>Math I’m learning</strong> — short notes, worked examples, intuition I wish someone had told me earlier.</li>
  <li><strong>Data projects</strong> — what I tried, what broke, and the chart that finally made sense.</li>
  <li><strong>Side observations</strong> — things from soccer, books, faith, anything that quietly shapes how I think.</li>
</ul>

<p>Posts will be short more often than long. If you want to follow along, there’s an <a href="/my-site/feed.xml">RSS feed</a> — or just check back when you’re curious.</p>

<p>Thanks for being here.</p>]]></content><author><name>Shanghao Wu</name></author><summary type="html"><![CDATA[Starting a blog feels like buying a new notebook — half the value is the blank page in front of you, and half is the quiet promise that you’ll show up to fill it.]]></summary></entry></feed>